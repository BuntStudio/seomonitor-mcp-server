{
  "name": "seomonitor-mcp-server",
  "version": "1.0.0",
  "description": "SEOMonitor MCP Server - Model Context Protocol server for SEOMonitor API integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "seomonitor-mcp": "bin/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "start:stdio": "node dist/index.js --transport stdio",
    "start:http": "node dist/index.js --transport http --port 3001",
    "start:ws": "node dist/index.js --transport websocket --port 3001",
    "docker:build": "docker build -f docker/Dockerfile -t seomonitor-mcp-server .",
    "docker:run": "docker run -p 3001:3001 seomonitor-mcp-server",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "seomonitor",
    "seo",
    "api",
    "claude",
    "ai"
  ],
  "author": "SEOMonitor",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seomonitor/mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/seomonitor/mcp-server/issues"
  },
  "homepage": "https://github.com/seomonitor/mcp-server#readme"
}
